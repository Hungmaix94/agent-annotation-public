{
  "manifest_version": 3,
  "name": "Agent Annotator",
  "version": "1.0.0",
  "description": "Annotate UI elements and sync context to local agents.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "http://localhost:*/*",
    "https://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://127.0.0.1:*/*",
    "http://localhost/*",
    "https://localhost/*",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/index.tsx-loader-B2XsJOJU.js"
      ],
      "matches": [
        "<all_urls>",
        "http://localhost:*/*",
        "https://localhost:*/*",
        "http://127.0.0.1:*/*",
        "https://127.0.0.1:*/*",
        "http://localhost/*",
        "https://localhost/*",
        "http://127.0.0.1/*",
        "https://127.0.0.1/*"
      ],
      "css": [
        "assets/jsx-runtime-C8cs_V01.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>",
        "http://127.0.0.1/*",
        "http://127.0.0.1:*/*",
        "http://localhost/*",
        "http://localhost:*/*",
        "https://127.0.0.1/*",
        "https://127.0.0.1:*/*",
        "https://localhost/*",
        "https://localhost:*/*"
      ],
      "resources": [
        "src/inject/react-fiber.js",
        "assets/*",
        "assets/jsx-runtime-BqeozZkb.js",
        "assets/index.tsx-DizVh17U.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
